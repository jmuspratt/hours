GOOGLE_PLACES_API_KEY=
DEPLOY_PATH=

# Edit-mode API proxy (scripts/api-server.js)
API_PORT=8787
APP_SHARED_SECRET=
ALLOWED_ORIGIN=http://localhost:3000
# Deploy target for scripts/deploy-api.sh — nest it alongside the site's own
# directory (sibling to the static webroot), not under its own /var/www entry,
# since it's a proxied service rather than a document root.
API_DEPLOY_PATH=